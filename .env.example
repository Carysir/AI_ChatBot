# ===== 大模型配置 =====
# 可选: zhipu / openai / qwen
LLM_PROVIDER=zhipu
LLM_API_KEY=your_api_key_here
LLM_MODEL=glm-4-flash
# LLM_BASE_URL=  # 可选，自定义 API 地址

# ===== 数据库 =====
DATABASE_URL=sqlite:///./chatbot.db

# ===== JWT =====
SECRET_KEY=change-this-to-a-random-string

# ===== RAG 配置 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
VECTOR_DB_PATH=./vector_store

# ===== 其他 =====
DEBUG=True
UPLOAD_DIR=./uploads
